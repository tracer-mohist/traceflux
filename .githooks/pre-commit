#!/bin/bash
# pre-commit - Automated code quality checks before commit
#
# Checks performed:
# 1. Python syntax validation
# 2. Code formatting (black)
# 3. Import sorting (isort)
# 4. Linting (flake8)
# 5. Type checking (mypy, optional)
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }

echo "🔍 Running pre-commit checks..."
echo ""

# Get staged Python files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [[ -z "$STAGED_FILES" ]]; then
    print_info "No Python files staged"
    exit 0
fi

print_info "Checking ${#STAGED_FILES[@]} Python file(s)..."
echo ""

ERRORS=0

# 1. Python syntax check
print_info "1/4 Checking Python syntax..."
for file in $STAGED_FILES; do
    if [[ -f "$file" ]]; then
        if ! python3 -m py_compile "$file" 2>/dev/null; then
            print_error "Syntax error in $file"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done
if [[ $ERRORS -eq 0 ]]; then
    print_success "Syntax check passed"
fi

# 2. Check formatting with black (if available)
print_info "2/4 Checking code formatting..."
if command -v black &> /dev/null; then
    UNFORMATTED=$(black --check --quiet $STAGED_FILES 2>&1 || true)
    if [[ -n "$UNFORMATTED" ]]; then
        print_warning "Code formatting issues found"
        print_info "Run 'black $STAGED_FILES' to fix"
        # Don't fail, just warn
    else
        print_success "Formatting check passed"
    fi
else
    print_warning "black not installed, skipping format check"
fi

# 3. Check imports with isort (if available)
print_info "3/4 Checking import order..."
if command -v isort &> /dev/null; then
    UNSORTED=$(isort --check-only --quiet $STAGED_FILES 2>&1 || true)
    if [[ -n "$UNSORTED" ]]; then
        print_warning "Import order issues found"
        print_info "Run 'isort $STAGED_FILES' to fix"
    else
        print_success "Import order check passed"
    fi
else
    print_warning "isort not installed, skipping import check"
fi

# 4. Linting with flake8 (if available)
print_info "4/4 Running linter..."
if command -v flake8 &> /dev/null; then
    LINT_ERRORS=$(flake8 --max-line-length=100 --ignore=E501,W503 $STAGED_FILES 2>&1 || true)
    if [[ -n "$LINT_ERRORS" ]]; then
        print_warning "Linting issues found:"
        echo "$LINT_ERRORS"
        # Don't fail on linting, just warn
    else
        print_success "Linting passed"
    fi
else
    print_warning "flake8 not installed, skipping lint check"
fi

echo ""
if [[ $ERRORS -gt 0 ]]; then
    print_error "Pre-commit checks failed with $ERRORS error(s)"
    exit 1
else
    print_success "All pre-commit checks passed"
    exit 0
fi
